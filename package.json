{
  "name": "jldec-astro",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "check": "astro check && prettier --check . && node check-links.js",
    "format": "prettier -w .",
    "ship": "astro build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "astro": "^6.1.8",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.83.0"
  },
  "prettier": {
    "printWidth": 120,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true,
    "semi": false,
    "trailingComma": "none"
  }
}
