---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
}

const { src } = Astro.props
---

<Image id="splashimage" src={src} alt="splash image" loading="eager" fetchpriority="high" class="h-42 w-full my-6 object-cover cursor-pointer rounded" />
